# Tribunal environment variables.
# Copy to .env and fill in real values. Never commit .env.

# -- Database --------------------------------------------------
# Postgres connection string (Neon or local).
DATABASE_URL=postgres://user:password@localhost:5432/tribunal

# Redis connection string (caching).
REDIS_URL=redis://localhost:6379

# -- Encryption ------------------------------------------------
# 32-byte key (base64) used to encrypt stored GitHub tokens.
ENCRYPTION_KEY=

# -- Neon Auth (managed identity + sessions) ------------------
PUBLIC_NEON_AUTH_URL=
NEON_AUTH_BASE_URL=

# -- GitHub OAuth (application repository access token) --------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional; defaults to http://localhost:5173/connect/github/account/callback in dev.
GITHUB_REDIRECT_URI=

# -- GitHub App (repository access + webhooks) -----------------
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# Optional: TTL (seconds) for the GitHub access cache.
GITHUB_ACCESS_CACHE_TTL=

# -- Local development -----------------------------------------
NODE_ENV=development
# Optional: set to enable verbose logging.
DEBUG=

# -- Tests (optional) ------------------------------------------
# Set to 1/true to enable strict PGlite timing assertions.
TRIBUNAL_TIMING_TESTS=
# Override the PGlite init budget in milliseconds (default 25000).
TRIBUNAL_TIMING_PGLITE_INIT=
