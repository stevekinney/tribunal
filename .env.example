# Tribunal environment variables.
# Copy to .env and fill in real values. Never commit .env.

# -- Database --------------------------------------------------
# Postgres connection string (Neon or local).
DATABASE_URL=postgres://user:password@localhost:5432/tribunal

# Redis connection string (caching).
REDIS_URL=redis://localhost:6379

# -- Encryption ------------------------------------------------
# 32-byte key encoded as 64 hex characters; shared by web, engine, and proxy.
ENCRYPTION_KEY=

# -- Neon Auth (managed identity + sessions) ------------------
PUBLIC_NEON_AUTH_URL=
NEON_AUTH_BASE_URL=

# -- GitHub OAuth (application repository access token) --------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional; defaults to http://localhost:5173/connect/github/account/callback in dev.
GITHUB_REDIRECT_URI=

# -- GitHub App (repository access + webhooks) -----------------
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# Optional: TTL (seconds) for the GitHub access cache.
GITHUB_ACCESS_CACHE_TTL=

# -- Review engine --------------------------------------------
# Internal engine control endpoint. In Fly production, web uses Fly private DNS:
# http://tribunal-engine.internal:3001
TRIBUNAL_ENGINE_URL=
TRIBUNAL_ENGINE_CONTROL_TOKEN=
# Optional bind hostname for the engine server. Fly private 6PN deploys set this
# to :: so tribunal-web can reach tribunal-engine.internal over IPv6.
TRIBUNAL_ENGINE_BIND_HOST=
# Durable Weft store. Set this only on tribunal-engine, never on tribunal-web.
# Keep it separate from DATABASE_URL.
WEFT_DATABASE_URL=
TENSORLAKE_API_KEY=
TRIBUNAL_SANDBOX_IMAGE=
# First production deploy must leave live execution disabled. Change only after
# the proxy CIDR, Tensorlake image, health checks, and fake load gate pass.
REVIEWS_ENABLED=false
TRIBUNAL_DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_DAILY_COST_CAP_USD=25
IDLE_SUSPEND_SECONDS=900
SANDBOX_REAP_INTERVAL=300
ENABLE_PROMPT_CACHING_1H=false
ANTHROPIC_ADMIN_KEY=
WEFT_INSPECTOR=false

# -- Review proxy ---------------------------------------------
ANTHROPIC_API_KEY=
TRIBUNAL_PROXY_URL=
# Dedicated public proxy IPv4 range, for example 203.0.113.10/32.
TRIBUNAL_PROXY_CIDR=
PROXY_CA_CERT=
PROXY_SIGNING_KEY=
GITHUB_EGRESS_ALLOW=github.com,api.github.com
ANTHROPIC_EGRESS_ALLOW=api.anthropic.com

# -- Local development -----------------------------------------
NODE_ENV=development
# Optional: set to enable verbose logging.
DEBUG=
# Optional: dev-only auth bypass. Set to 1 to auto-log-in a local user so the
# authenticated UI is reachable without completing GitHub OAuth (useful inside
# preview sandboxes where the OAuth redirect can't complete). Ignored outside a
# dev runtime, and the server refuses to start if it's armed in production.
DEV_AUTH_BYPASS=
# Optional: username for the bypass user (default "dev"). Created on first use.
DEV_AUTH_BYPASS_USER=

# -- Tests (optional) ------------------------------------------
# Set to 1/true to enable strict PGlite timing assertions.
TRIBUNAL_TIMING_TESTS=
# Override the PGlite init budget in milliseconds (default 25000).
TRIBUNAL_TIMING_PGLITE_INIT=
