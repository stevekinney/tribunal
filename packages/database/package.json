{
  "name": "@tribunal/database",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/types": "./src/schema/types.ts",
    "./operators": "./src/operators.ts",
    "./queries": "./src/queries/index.ts",
    "./validation/user-api-key": "./src/validation/user-api-key.ts"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run --config vitest.configuration.ts",
    "check:migrations": "bun run scripts/check-migration-consistency.ts",
    "db:tables": "bun run scripts/list-database-tables.ts",
    "db:test-migrations": "bun src/test/run-migration-tests.ts",
    "db:validate-invariants": "bun src/test/validate-invariants.ts",
    "db:detect-drift": "bun src/test/detect-drift.ts",
    "test:migrations": "vitest run --config vitest.configuration.ts src/test/__tests__",
    "test:migrations:unit": "vitest run --config vitest.configuration.ts src/test/__tests__/validate-invariants.test.ts",
    "test:migrations:integration": "vitest run --config vitest.configuration.ts src/test/__tests__/migration-scenarios.test.ts",
    "test:migrations:watch": "vitest --config vitest.configuration.ts --watch src/test/__tests__",
    "lint": "oxlint . && eslint .",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore ."
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "chalk": "^5.6.2",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tribunal/typescript": "workspace:*",
    "@neondatabase/api-client": "^1.6.0",
    "change-case": "^5.4.4",
    "drizzle-kit": "^0.31.8"
  }
}
