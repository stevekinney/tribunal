{
  "extends": "@tribunal/typescript/library.json",
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "@sveltejs/kit"],
    "paths": {
      "$lib/*": ["../../applications/web/src/lib/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
