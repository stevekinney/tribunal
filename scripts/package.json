{
  "name": "@tribunal/scripts",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "validate:skills": "bun run validate-skill-wiring.ts",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write --ignore-path ../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../.prettierignore .",
    "test:coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@tribunal/database": "workspace:*",
    "@tribunal/github": "workspace:*",
    "chalk": "^5.6.2",
    "prose-writer": "^0.1.3",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-remove": "^4.0.0"
  },
  "devDependencies": {
    "@tribunal/typescript": "workspace:*",
    "@types/mdast": "^4.0.4",
    "bun-types": "^1.3.4",
    "vitest": "^4.0.16"
  }
}
