{
  "name": "@tribunal/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "test": "bun run test:unit:server && bun run test:unit:client",
    "test:e2e": "bun run --cwd ../../packages/review-core build && bun run --cwd ../../packages/agents build && bun run build && playwright test",
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "postinstall": "svelte-kit sync",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit:server": "vitest run --project server",
    "test:unit:client": "vitest run --project client --passWithNoTests",
    "lint": "oxlint . && eslint .",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore ."
  },
  "dependencies": {
    "@lostgradient/cinder": "0.16.1",
    "@lostgradient/weft": "^0.10.0",
    "@milkdown/ctx": "^7.17.3",
    "@milkdown/kit": "^7.17.3",
    "@milkdown/prose": "^7.17.3",
    "@neondatabase/neon-js": "^0.6.1-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@shikijs/engine-oniguruma": "^3.21.0",
    "@shikijs/langs": "^3.21.0",
    "@shikijs/rehype": "^3.21.0",
    "@shikijs/types": "^3.21.0",
    "@tribunal/agents": "workspace:*",
    "@tribunal/database": "workspace:*",
    "@tribunal/github": "workspace:*",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.0",
    "arctic": "^3.7.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "github-webhook-schemas": "1.1.0",
    "hast-util-sanitize": "^5.0.0",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.0",
    "lucide-svelte": "^0.561.0",
    "octokit": "^5.0.5",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.3",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "shiki": "^3.21.0",
    "unified": "^11.0.5",
    "unist-util-remove": "^4.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@electric-sql/pglite": "^0.3.14",
    "@octokit/types": "^16.0.0",
    "@playwright/test": "^1.57.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.49.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tribunal/agents": "workspace:*",
    "@tribunal/review-core": "workspace:*",
    "@tribunal/test": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
