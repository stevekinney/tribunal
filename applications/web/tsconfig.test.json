{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // More liberal settings for test files
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    // Allow synthetic default imports for test utilities
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "test/**/*.ts",
    "test/**/*.svelte",
    "documentation/**/*.ts",
    "documentation/**/*.svelte",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "workers/**/*.test.ts",
    "workers/**/*.spec.ts"
  ]
}
