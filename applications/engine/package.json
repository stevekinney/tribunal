{
  "name": "@tribunal/engine",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --external tensorlake",
    "check": "tsc --noEmit",
    "test": "vitest run --config vitest.configuration.ts",
    "test:coverage": "vitest run --config vitest.configuration.ts --coverage",
    "lint": "oxlint . && eslint .",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.181",
    "@lostgradient/weft": "0.6.0",
    "@neondatabase/serverless": "^1.0.2",
    "@tribunal/cost": "workspace:*",
    "@tribunal/database": "workspace:*",
    "@tribunal/github": "workspace:*",
    "@tribunal/review-core": "workspace:*",
    "@tribunal/sandbox": "workspace:*",
    "tensorlake": "0.5.47",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tribunal/test": "workspace:*",
    "@tribunal/typescript": "workspace:*",
    "@types/node": "^25",
    "bun-types": "^1.3.4",
    "vitest": "^4.0.16"
  }
}
